    "dependencies": [
        {
            "description": "CUDA is a parallel computing platform and programming model invented by\nNVIDIA. It enables dramatic increases in computing performance by\nharnessing the power of the graphics processing unit (GPU). Note: This\npackage does not currently install the drivers necessary to run CUDA.\nThese will need to be installed manually. See:\nhttps://docs.nvidia.com/cuda/ for details.",
            "name": "cuda"
        },
        {
            "description": "Modern, extensible Python build backend.",
            "name": "py-hatchling"
        },
        {
            "description": "Differentiate, compile, and transform Numpy code. JAX is a Python\nlibrary for accelerator-oriented array computation and program\ntransformation, designed for high-performance numerical computing and\nlarge-scale machine learning.",
            "name": "py-jax"
        },
        {
            "description": "XLA library for Jax. jaxlib is the support library for JAX. While JAX\nitself is a pure Python package, jaxlib contains the binary (C/C++)\nparts of the library, including Python bindings, the XLA compiler, the\nPJRT runtime, and a handful of handwritten kernels.",
            "name": "py-jaxlib"
        },
        {
            "description": "Type annotations and runtime checking for shape and dtype of JAX arrays,\nand PyTrees.",
            "name": "py-jaxtyping"
        },
        {
            "description": "The PyPA recommended tool for installing Python packages.",
            "name": "py-pip"
        },
        {
            "description": "The typing_extensions module contains both backports of these changes as\nwell as experimental types that will eventually be added to the typing\nmodule, such as Protocol (see PEP 544 for details about protocols and\nstatic duck typing).",
            "name": "py-typing-extensions"
        },
        {
            "description": "A Wadler\u2013Lindig pretty-printer for Python",
            "name": "py-wadler-lindig"
        },
        {
            "description": "A built-package format for Python.",
            "name": "py-wheel"
        },
        {
            "description": "The Python programming language.",
            "name": "python"
        },
        {
            "description": "A Spack managed Python virtual environment",
            "name": "python-venv"
        }
    ],
    "dependent_to": [
        {
            "description": "APEBench is a JAX-based tool to evaluate autoregressive neural emulators\nfor PDEs on periodic domains in 1d, 2d, and 3d. It comes with an\nefficient reference simulator based on spectral methods that is used for\nprocedural data generation (no need to download large datasets with\nAPEBench). Since this simulator can also be embedded into emulator\ntraining (e.g., for a \"solver-in-the-loop\" correction setting), this is\nthe first benchmark suite to support differentiable physics.",
            "name": "py-apebench"
        },
        {
            "description": "Efficient Differentiable n-d PDE solvers built on top of JAX & Equinox.",
            "name": "py-exponax"
        },
        {
            "description": "A collection of neural architectures for emulating Partial Differential\nEquations (PDEs) in JAX agnostic to the spatial dimension (1D, 2D, 3D)\nand boundary conditions (Dirichlet, Neumann, Periodic). This package is\nbuilt on top of Equinox.",
            "name": "py-pdequinox"
        },
        {
            "description": "Convenience abstractions using optax to train neural networks to\nautoregressively emulate time-dependent problems taking care of\ntrajectory subsampling and offering a wide range of training\nmethodologies (regarding unrolling length and including differentiable\nphysics).",
            "name": "py-trainax"
        }
    ],
    "description": "Equinox is your one-stop [JAX](https://github.com/google/jax) library,\nfor everything you need that isn't already in core JAX: - neural\nnetworks (or more generally any model), with easy-to-use PyTorch-like\nsyntax; - filtered APIs for transformations; - useful PyTree\nmanipulation routines; - advanced features like runtime errors; and best\nof all, Equinox isn't a framework: everything you write in Equinox is\ncompatible with anything else in JAX or the ecosystem.\n",
    "homepage": "https://docs.kidger.site/equinox/",
    "latest_version": "0.13.4",
    "maintainers": [
        "abhishek1297"
    ],
